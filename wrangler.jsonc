/**
 * For more details on how to configure Wrangler, refer to:
 * https://developers.cloudflare.com/workers/wrangler/configuration/
 */
{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "cursor-linear-webhooks-issues",
	"main": "src/index.ts",
	"compatibility_date": "2026-04-14",
	"observability": {
		"enabled": true
	},
	"upload_source_maps": true,
	"compatibility_flags": [
		"nodejs_compat"
	],
	"vars": {
		"CURSOR_WEBHOOK_REFINE_ISSUES": "https://api2.cursor.sh/automations/webhook/63867baf-7c7d-41e8-ad85-397025af184e",
		"CURSOR_WEBHOOK_IMPLEMENT_PR": "https://api2.cursor.sh/automations/webhook/a76c9191-f135-41cb-8265-c61e20e651f8",
		"CURSOR_WEBHOOK_REVIEW_FIXER": "https://api2.cursor.sh/automations/webhook/46b28247-9439-43c2-b013-ab227d670a26",
		"CURSOR_WEBHOOK_BOT_ROUTING": "https://api2.cursor.sh/automations/webhook/62805864-9957-4623-887f-29203b2a2432"
	},
	"env": {
		"test": {
			"vars": {
				"LINEAR_WEBHOOK_SECRET": "test-secret",
				"LINEAR_API_KEY": "test-linear-api-key",
				"LINEAR_REPLAY_WINDOW_MS": "600000",
				"CURSOR_WEBHOOK_REFINE_ISSUES": "https://cursor.test/hooks/refine-issues",
				"CURSOR_WEBHOOK_REFINE_ISSUES_AUTH_TOKEN": "test-token-refine-issues",
				"CURSOR_WEBHOOK_IMPLEMENT_PR": "https://cursor.test/hooks/implement-pr",
				"CURSOR_WEBHOOK_IMPLEMENT_PR_AUTH_TOKEN": "test-token-implement-pr",
				"CURSOR_WEBHOOK_REVIEW_FIXER": "https://cursor.test/hooks/review-fixer",
				"CURSOR_WEBHOOK_REVIEW_FIXER_AUTH_TOKEN": "test-token-review-fixer",
				"CURSOR_WEBHOOK_REVIEW_GATE": "https://cursor.test/placeholder/review-gate",
				"CURSOR_WEBHOOK_PLACEHOLDER_ISSUE_CREATED": "https://cursor.test/hooks/placeholder-issue-created",
				"CURSOR_WEBHOOK_PLACEHOLDER_ISSUE_CREATED_AUTH_TOKEN": "test-token-issue-created",
				"CURSOR_WEBHOOK_PLACEHOLDER_DONE": "https://cursor.test/hooks/placeholder-done",
				"CURSOR_WEBHOOK_PLACEHOLDER_DONE_AUTH_TOKEN": "test-token-done",
				"CURSOR_WEBHOOK_PLACEHOLDER_LABEL_BLOCKED_REMOVED": "https://cursor.test/hooks/placeholder-label",
				"CURSOR_WEBHOOK_PLACEHOLDER_LABEL_BLOCKED_REMOVED_AUTH_TOKEN": "test-token-label-removed",
				"CURSOR_WEBHOOK_PLACEHOLDER_COMMENT": "https://cursor.test/hooks/placeholder-comment",
				"CURSOR_WEBHOOK_PLACEHOLDER_COMMENT_AUTH_TOKEN": "test-token-comment",
				"CURSOR_WEBHOOK_PLACEHOLDER_REACTION_THUMBSUP": "https://cursor.test/hooks/placeholder-reaction",
				"CURSOR_WEBHOOK_PLACEHOLDER_REACTION_THUMBSUP_AUTH_TOKEN": "test-token-reaction-thumbsup",
				"CURSOR_WEBHOOK_BOT_ROUTING": "https://cursor.test/hooks/placeholder-reaction-robot-face",
				"CURSOR_WEBHOOK_BOT_ROUTING_AUTH_TOKEN": "test-token-bot-routing"
			}
		}
	}
	/**
	 * Smart Placement
	 * https://developers.cloudflare.com/workers/configuration/smart-placement/#smart-placement
	 */
	// "placement": {  "mode": "smart" }
	/**
	 * Bindings
	 * Bindings allow your Worker to interact with resources on the Cloudflare Developer Platform, including
	 * databases, object storage, AI inference, real-time communication and more.
	 * https://developers.cloudflare.com/workers/runtime-apis/bindings/
	 */
	/**
	 * Environment Variables
	 * https://developers.cloudflare.com/workers/wrangler/configuration/#environment-variables
	 * Note: Use secrets to store sensitive data.
	 * https://developers.cloudflare.com/workers/configuration/secrets/
	 */
	// "vars": {  "MY_VARIABLE": "production_value" }
	/**
	 * Static Assets
	 * https://developers.cloudflare.com/workers/static-assets/binding/
	 */
	// "assets": {  "directory": "./public/",  "binding": "ASSETS" }
	/**
	 * Service Bindings (communicate between multiple Workers)
	 * https://developers.cloudflare.com/workers/wrangler/configuration/#service-bindings
